鬠ｿ# .htaccess para produﾃδｧﾃδ｣o (Apache)
# Seguranﾃδｧa bﾃδ｡sica
ServerSignature Off
Header always unset X-Powered-By
Header set X-Frame-Options "SAMEORIGIN"
Header set X-Content-Type-Options "nosniff"
Header set Referrer-Policy "strict-origin-when-cross-origin"
# HSTS (somente se HTTPS)
<If "%{HTTPS} = 'on'">
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</If>

# Cache e compressﾃδ｣o de assets
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css application/javascript application/json image/svg+xml
</IfModule>
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 30 days"
  ExpiresByType application/javascript "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/gif "access plus 30 days"
</IfModule>

# Bloquear acesso direto a pastas sensﾃδｭveis
RedirectMatch 403 ^/(config|core|helpers|vendor|tests|scripts)/?.*$

# Roteamento opcional (se necessﾃδ｡rio), manter arquivos existentes
# RewriteEngine On
# RewriteCond %{REQUEST_FILENAME} !-f
# RewriteCond %{REQUEST_FILENAME} !-d
# RewriteRule ^ index.php [L]

# Roteamento: permitir URLs sem extensao (.php)
# Ex.: /ged/tipos_listar -> /ged/tipos_listar.php
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Mantﾃｩm acesso direto a arquivos/pastas reais
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  # Se existir um .php correspondente, servir sem a extensﾃ｣o
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.php -f
  RewriteRule ^(.+)$ $1.php [L,QSA]
</IfModule>

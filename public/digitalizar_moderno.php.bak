    <script>
        const fileInput = document.getElementById('arquivo');
        const preview = document.getElementById('preview');
        const form = document.getElementById('form-scan');
        const btnScanner = document.getElementById('btn-scanner');
        const scannerContainer = document.getElementById('scanner-container');
        const videoScanner = document.getElementById('video-scanner');
        const canvasScanner = document.getElementById('canvas-scanner');
        const photoPreview = document.getElementById('photo-preview');
        const btnCapturar = document.getElementById('btn-capturar');
        const btnFecharCamera = document.getElementById('btn-fechar-camera');
        const scannerButtons = document.getElementById('scanner-buttons');

        let mediaStream = null;
        let fotoCapturada = null;

        // Abrir câmera
        btnScanner.addEventListener('click', async function() {
            try {
                if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                    alert('Câmera não disponível neste navegador');
                    return;
                }

                mediaStream = await navigator.mediaDevices.getUserMedia({ 
                    video: { facingMode: 'environment', width: { ideal: 1920 } } 
                });

                videoScanner.srcObject = mediaStream;
                videoScanner.style.display = 'block';
                photoPreview.style.display = 'none';
                scannerContainer.style.display = 'flex';
                btnScanner.style.display = 'none';
                btnCapturar.style.display = 'block';

                videoScanner.play();
            } catch (error) {
                console.error('Erro ao acessar câmera:', error);
                alert('Permissão de câmera negada ou não disponível');
            }
        });

        // Capturar foto
        btnCapturar.addEventListener('click', function() {
            canvasScanner.width = videoScanner.videoWidth;
            canvasScanner.height = videoScanner.videoHeight;
            
            const ctx = canvasScanner.getContext('2d');
            ctx.drawImage(videoScanner, 0, 0);
            
            fotoCapturada = canvasScanner.toDataURL('image/jpeg', 0.9);
            photoPreview.src = fotoCapturada;
            photoPreview.style.display = 'block';
            videoScanner.style.display = 'none';
            btnCapturar.innerHTML = '<i class="fas fa-check"></i> Usar Esta Foto';
            
            // Mudar função do botão para usar a foto
            btnCapturar.onclick = function() {
                fecharCamera();
                converterFotoParaPDF(fotoCapturada);
            };
        });

        // Fechar câmera
        btnFecharCamera.addEventListener('click', function() {
            fecharCamera();
        });

        function fecharCamera() {
            if (mediaStream) {
                mediaStream.getTracks().forEach(track => track.stop());
                mediaStream = null;
            }
            scannerContainer.style.display = 'none';
            btnScanner.style.display = 'block';
            photoPreview.style.display = 'none';
            videoScanner.style.display = 'none';
            btnCapturar.innerHTML = '<i class="fas fa-camera"></i> Capturar';
            btnCapturar.onclick = null;
            fotoCapturada = null;
        }

        // Converter foto para PDF
        function converterFotoParaPDF(imagemBase64) {
            // Carregar biblioteca jsPDF
            const script = document.createElement('script');
            script.src = 'https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js';
            document.head.appendChild(script);

            script.onload = function() {
                // Criar imagem a partir do base64
                const img = new Image();
                img.src = imagemBase64;
                
                img.onload = function() {
                    // Criar elemento para conversão
                    const element = document.createElement('div');
                    element.appendChild(img);
                    
                    const opt = {
                        margin: 5,
                        filename: 'documento_' + new Date().getTime() + '.pdf',
                        image: { type: 'jpeg', quality: 0.98 },
                        html2canvas: { scale: 2 },
                        jsPDF: { orientation: 'portrait', unit: 'mm', format: 'a4' }
                    };

                    html2pdf().set(opt).from(element).save();
                    
                    // Mostrar sucesso
                    alert('PDF gerado! O arquivo foi baixado. Você pode carregá-lo agora.');
                };
            };
        }

        // Preview do arquivo
        fileInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            
            if (!file) {
                preview.innerHTML = '<i class="fas fa-file-pdf"></i><p class="text-muted">Nenhum arquivo selecionado</p>';
                return;
            }

            // Validar tipo
            if (file.type !== 'application/pdf') {
                alert('Por favor, selecione um arquivo PDF');
                fileInput.value = '';
                preview.innerHTML = '<i class="fas fa-file-pdf"></i><p class="text-muted">Apenas PDF é aceito</p>';
                return;
            }

            // Validar tamanho (50MB)
            if (file.size > 50 * 1024 * 1024) {
                alert('Arquivo muito grande (máximo 50 MB)');
                fileInput.value = '';
                preview.innerHTML = '<i class="fas fa-file-pdf"></i><p class="text-muted">Arquivo muito grande</p>';
                return;
            }

            // Mostrar preview
            const reader = new FileReader();
            reader.onload = function(evt) {
                preview.innerHTML = `
                    <div style="text-align: center; width: 100%;">
                        <i class="fas fa-check-circle" style="color: #10b981; font-size: 3rem; margin-bottom: 1rem;"></i>
                        <p><strong>${file.name}</strong></p>
                        <p class="text-muted">${(file.size / 1024 / 1024).toFixed(2)} MB</p>
                    </div>
                `;
            };
            reader.readAsArrayBuffer(file);
        });

        // Submit do formulário
        form.addEventListener('submit', async function(e) {
            e.preventDefault();

            const file = fileInput.files[0];
            if (!file) {
                alert('Selecione um arquivo');
                return;
            }

            const titulo = document.getElementById('titulo').value.trim();
            if (!titulo) {
                alert('Preencha o título');
                return;
            }

            const btn = form.querySelector('button[type="submit"]');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Enviando...';

            try {
                const formData = new FormData();
                formData.append('documento_digitalizado', file);
                formData.append('titulo', titulo);
                formData.append('tipo_documento_id', document.getElementById('tipo_documento_id').value);
                formData.append('captura_modo', 'upload_manual');
                formData.append('conteudo_ocr', document.getElementById('chk-ocr').checked ? '1' : '0');

                const response = await fetch('digitalizar_processar.php', {
                    method: 'POST',
                    body: formData
                });

                const text = await response.text();
                console.log('Resposta:', text);

                try {
                    const data = JSON.parse(text);
                    if (data.sucesso) {
                        alert('✅ Documento salvo com sucesso!');
                        window.location.href = 'index.php';
                    } else {
                        alert('❌ Erro: ' + data.mensagem);
                    }
                } catch (e) {
                    alert('Erro ao processar resposta: ' + text);
                }
            } catch (error) {
                console.error('Erro:', error);
                alert('Erro ao enviar: ' + error.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-cloud-upload-alt"></i> Enviar Documento';
            }
        });

        console.log('✅ Sistema de digitalização carregado (Câmera + Upload)');
    </script>
</body>
</html>
</head>
